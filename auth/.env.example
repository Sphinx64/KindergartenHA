# JWT-Konfiguration
# Starkes Geheimnis erzeugen: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Home Assistant
HA_BASE_URL=http://localhost:8123
# Long-Lived Token in HA unter Profil → Sicherheit → Token erstellen
HA_LONG_LIVED_TOKEN=
